#!/usr/bin/env python3
"""
f5_virtual_servers.py

Connects to F5 LTM devices via a jump server and extracts virtual server
information using Netmiko and multithreading.

Usage:
    python f5_virtual_servers.py [--inventory inventory.txt] [--output output.csv]
                                  [--threads 10] [--jump-user USER] [--jump-key PATH]

Requirements:
    pip install netmiko paramiko
"""

import argparse
import csv
import getpass
import json
import os
import re
import sys
from concurrent.futures import ThreadPoolExecutor, as_completed
from datetime import datetime

import paramiko
from netmiko import ConnectHandler
from netmiko.exceptions import NetMikoAuthenticationException, NetMikoTimeoutException

# ---------------------------------------------------------------------------
# Configuration – override via CLI args or environment variables
# ---------------------------------------------------------------------------
JUMP_HOST = os.environ.get("JUMP_HOST", "jumpbox.server.com")
JUMP_PORT = int(os.environ.get("JUMP_PORT", 22))
JUMP_USER = os.environ.get("JUMP_USER", "")
JUMP_PASSWORD = os.environ.get("JUMP_PASSWORD", "")
JUMP_KEY_FILE = os.environ.get("JUMP_KEY_FILE", "")  # path to private key

F5_PORT = int(os.environ.get("F5_PORT", 22))
DEFAULT_THREADS = 10
COMMAND_TIMEOUT = 60  # seconds


# ---------------------------------------------------------------------------
# Jump-server channel helper
# ---------------------------------------------------------------------------

def _build_jump_client(jump_host, jump_port, jump_user, jump_password, jump_key_file):
    """Return an authenticated paramiko SSHClient connected to the jump server."""
    client = paramiko.SSHClient()
    client.set_missing_host_key_policy(paramiko.AutoAddPolicy())

    connect_kwargs = {
        "hostname": jump_host,
        "port": jump_port,
        "username": jump_user,
        "password": jump_password,
        "timeout": 30,
        "allow_agent": False,
        "look_for_keys": False,
        "banner_timeout": 200,
    }

    if jump_key_file:
        connect_kwargs["key_filename"] = jump_key_file
        connect_kwargs["look_for_keys"] = True

    client.connect(**connect_kwargs)
    return client


def _open_channel(jump_client, target_host, target_port):
    """
    Open a proxy channel to target_host:target_port through the jump server.

    Tries direct-tcpip first (fastest). If the jump server blocks it with
    'administratively prohibited' (PermitOpen restriction), falls back to
    running `nc` via an exec channel, which bypasses PermitOpen rules.
    """
    transport = jump_client.get_transport()

    # Attempt 1: direct-tcpip
    try:
        dest_addr = (target_host, target_port)
        src_addr = ("127.0.0.1", 0)
        channel = transport.open_channel("direct-tcpip", dest_addr, src_addr)
        return channel
    except paramiko.ChannelException:
        pass  # fall through to nc fallback

    # Attempt 2: exec channel running netcat on the jump server
    channel = transport.open_session()
    channel.set_combine_stderr(True)   # prevent nc stderr from blocking reads
    channel.settimeout(200)            # match banner_timeout so reads don't expire early
    channel.exec_command(f"nc -w 60 {target_host} {target_port}")
    return channel


# ---------------------------------------------------------------------------
# Parsing helpers
# ---------------------------------------------------------------------------

def _parse_virtual_servers(raw_output):
    """
    Parse `list ltm virtual` output into a list of dicts.

    Each dict contains:
        name, destination, ip, port, pool, ip_protocol, state, enabled
    """
    virtual_servers = []
    current = None

    for line in raw_output.splitlines():
        stripped = line.strip()

        # Detect start of a new virtual-server block
        if re.match(r"^ltm virtual\s+\S+", stripped):
            if current is not None:
                virtual_servers.append(current)
            vs_name = re.sub(r"\s*\{.*", "", stripped.replace("ltm virtual ", "")).strip()
            current = {
                "name": vs_name,
                "destination": "",
                "ip": "",
                "port": "",
                "pool": "",
                "ip_protocol": "",
                "state": "",
                "enabled": "",
            }
            continue

        if current is None:
            continue

        if stripped.startswith("destination "):
            dest = stripped.split("destination ", 1)[1].strip()
            current["destination"] = dest
            # Parse IP and port from formats like 10.0.0.1:80 or /Common/10.0.0.1:80
            match = re.search(r"([\d.]+):(\d+)$", dest)
            if match:
                current["ip"] = match.group(1)
                current["port"] = match.group(2)

        elif stripped.startswith("pool "):
            current["pool"] = stripped.split("pool ", 1)[1].strip()

        elif stripped.startswith("ip-protocol "):
            current["ip_protocol"] = stripped.split("ip-protocol ", 1)[1].strip()

        elif stripped.startswith("enabled-vlans"):
            pass  # skip sub-block header

        elif stripped == "enabled":
            current["enabled"] = "yes"

        elif stripped == "disabled":
            current["enabled"] = "no"

    if current is not None:
        virtual_servers.append(current)

    return virtual_servers


def _parse_ssl_certs(raw_output):
    """
    Parse `list sys file ssl-cert all-properties` output into a list of dicts.
    """
    from datetime import timezone

    certs = []
    current = None

    for line in raw_output.splitlines():
        stripped = line.strip()

        if re.match(r"^sys (crypto cert|file ssl-cert)\s+\S+", stripped):
            if current is not None:
                certs.append(current)
            name = re.sub(r"\s*\{.*", "", re.sub(r"^sys (crypto cert|file ssl-cert)\s+", "", stripped)).strip()
            current = {
                "name":                    name,
                "common_name":             "",
                "subject":                 "",
                "issuer":                  "",
                "issuer_cert":             "",
                "organization":            "",
                "ou":                      "",
                "country":                 "",
                "state":                   "",
                "city":                    "",
                "email":                   "",
                "subject_alternative_name":"",
                "key_type":                "",
                "key_size":                "",
                "serial_number":           "",
                "sha1_fingerprint":        "",
                "fingerprint":             "",
                "validity_start_string":   "",
                "validity_start_date":     "",
                "expiration_string":       "",
                "expiration_date":         "",
                "days_until_expiry":       "",
                "cert_validators":         "",
                "cache_path":              "",
            }
            continue

        if current is None:
            continue

        def _val(prefix):
            return stripped.split(prefix, 1)[1].strip().strip('"')

        if stripped.startswith("common-name "):
            current["common_name"] = _val("common-name ")
        elif stripped.startswith("subject "):
            current["subject"] = _val("subject ")
        elif stripped.startswith("issuer "):
            current["issuer"] = _val("issuer ")
        elif stripped.startswith("issuer-cert "):
            current["issuer_cert"] = _val("issuer-cert ")
        elif stripped.startswith("organization "):
            current["organization"] = _val("organization ")
        elif re.match(r"^ou\s+", stripped):
            current["ou"] = _val("ou ")
        elif stripped.startswith("country "):
            current["country"] = _val("country ")
        elif stripped.startswith("state "):
            current["state"] = _val("state ")
        elif stripped.startswith("city "):
            current["city"] = _val("city ")
        elif stripped.startswith("email "):
            current["email"] = _val("email ")
        elif stripped.startswith("subject-alternative-name "):
            san = _val("subject-alternative-name ")
            current["subject_alternative_name"] = "" if san == "none" else san
        elif stripped.startswith("key-type "):
            current["key_type"] = _val("key-type ")
        elif stripped.startswith("key-size "):
            current["key_size"] = _val("key-size ")
        elif stripped.startswith("serial-number "):
            current["serial_number"] = _val("serial-number ")
        elif stripped.startswith("sha1-fingerprint "):
            current["sha1_fingerprint"] = _val("sha1-fingerprint ")
        elif stripped.startswith("fingerprint "):
            current["fingerprint"] = _val("fingerprint ")
        elif stripped.startswith("validity-start-string "):
            current["validity_start_string"] = _val("validity-start-string ")
        elif stripped.startswith("validity-start-date "):
            current["validity_start_date"] = _val("validity-start-date ")
        elif stripped.startswith("expiration-string "):
            current["expiration_string"] = _val("expiration-string ")
        elif stripped.startswith("expiration-date "):
            ts = _val("expiration-date ")
            current["expiration_date"] = ts
            try:
                exp_dt = datetime.fromtimestamp(int(ts), tz=timezone.utc)
                now_dt = datetime.now(tz=timezone.utc)
                current["days_until_expiry"] = (exp_dt - now_dt).days
            except Exception:
                pass
        elif stripped.startswith("cert-validators "):
            current["cert_validators"] = _val("cert-validators ")
        elif stripped.startswith("cache-path "):
            current["cache_path"] = _val("cache-path ")

    if current is not None:
        certs.append(current)

    return certs


# ---------------------------------------------------------------------------
# Per-device worker
# ---------------------------------------------------------------------------

def collect_virtual_servers(host, username, password, jump_config):
    """
    Connect to a single F5 LTM device through the jump server and return
    a result dict with virtual server details.

    Parameters
    ----------
    host       : str  – target F5 hostname or IP
    username   : str  – F5 username
    password   : str  – F5 password
    jump_config : dict – keys: host, port, user, password, key_file

    Returns
    -------
    dict with keys: host, virtual_servers (list), raw_output (str), error (str|None)
    """
    result = {
        "host": host,
        "virtual_servers": [],
        "ssl_certs": [],
        "raw_output": "",
        "raw_certs_output": "",
        "error": None,
        "timestamp": datetime.now().isoformat(timespec="seconds"),
    }

    jump_client = None
    net_connect = None

    try:
        # 1. Establish jump-server connection
        print(f"[{host}] Connecting to jump server {jump_config['host']}...")
        jump_client = _build_jump_client(
            jump_config["host"],
            jump_config["port"],
            jump_config["user"],
            jump_config["password"],
            jump_config["key_file"],
        )
        print(f"[{host}] Connected to jump server {jump_config['host']}")

        # 2. Open a proxy channel to the target F5
        print(f"[{host}] Opening proxy channel to {host}:{F5_PORT}...")
        channel = _open_channel(jump_client, host, F5_PORT)
        print(f"[{host}] Proxy channel established to {host}")

        # 3. Connect to F5 via Netmiko using the proxy socket
        print(f"[{host}] Connecting to F5 LTM...")
        device_params = {
            "device_type": "f5_ltm",
            "host": host,
            "port": F5_PORT,
            "username": username,
            "password": password,
            "sock": channel,
            "use_keys": False,
            "allow_agent": False,
            "timeout": COMMAND_TIMEOUT,
            "session_timeout": COMMAND_TIMEOUT,
            "conn_timeout": 60,
            "banner_timeout": 200,
            "auth_timeout": 60,
            "global_delay_factor": 2,
        }

        net_connect = ConnectHandler(**device_params)
        print(f"[{host}] Connected to F5 LTM — running 'list ltm virtual'...")

        # 4. Collect virtual servers
        raw = net_connect.send_command(
            "list ltm virtual",
            read_timeout=COMMAND_TIMEOUT,
        )
        result["raw_output"] = raw
        result["virtual_servers"] = _parse_virtual_servers(raw)

        # 5. Collect SSL certificates
        print(f"[{host}] Running 'list sys file ssl-cert all-properties'...")
        raw_certs = net_connect.send_command(
            "list sys file ssl-cert all-properties",
            read_timeout=COMMAND_TIMEOUT,
        )
        result["raw_certs_output"] = raw_certs
        result["ssl_certs"] = _parse_ssl_certs(raw_certs)

    except NetMikoAuthenticationException as exc:
        result["error"] = f"Authentication failed: {exc}"
    except NetMikoTimeoutException as exc:
        result["error"] = f"Connection timed out: {exc}"
    except paramiko.AuthenticationException as exc:
        result["error"] = f"Jump server authentication failed: {exc}"
    except Exception as exc:
        result["error"] = f"{type(exc).__name__}: {exc}"
    finally:
        try:
            if net_connect:
                net_connect.disconnect()
        except Exception:
            pass
        try:
            if jump_client:
                jump_client.close()
        except Exception:
            pass

    return result


# ---------------------------------------------------------------------------
# Inventory loader
# ---------------------------------------------------------------------------

def load_inventory(path):
    """
    Load hostnames/IPs from an inventory file – one entry per line.
    Lines starting with '#' or blank lines are ignored.
    """
    hosts = []
    with open(path) as fh:
        for lineno, raw in enumerate(fh, start=1):
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            if not line:
                print(f"[WARN] inventory line {lineno} skipped (empty): {raw!r}")
                continue
            hosts.append(line)
    return hosts


# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------

def _print_results(results):
    """Pretty-print results to stdout."""
    for r in results:
        host = r["host"]
        ts = r["timestamp"]
        if r["error"]:
            print(f"\n[ERROR] {host} ({ts}): {r['error']}")
            continue

        # Virtual servers
        vss = r["virtual_servers"]
        print(f"\n[OK] {host} ({ts}) – {len(vss)} virtual server(s) found")
        if vss:
            header = f"  {'Name':<40} {'Destination':<22} {'Pool':<30} {'Proto':<6} {'Enabled'}"
            print(header)
            print("  " + "-" * (len(header) - 2))
            for vs in vss:
                print(
                    f"  {vs['name']:<40} {vs['destination']:<22} "
                    f"{vs['pool']:<30} {vs['ip_protocol']:<6} {vs['enabled']}"
                )
        else:
            print("  (no virtual servers configured)")

        # SSL certificates
        certs = r.get("ssl_certs", [])
        print(f"\n  SSL Certificates: {len(certs)} found")
        if certs:
            cert_header = f"  {'Name':<45} {'Subject':<40} {'Expiry':<28} {'Days Left':>9}"
            print(cert_header)
            print("  " + "-" * (len(cert_header) - 2))
            for c in certs:
                days = c["days_until_expiry"]
                if isinstance(days, int):
                    days_str = f"{days:>9}"
                    if days < 0:
                        days_str = f"{'EXPIRED':>9}"
                    elif days <= 30:
                        days_str = f"{'⚠ ' + str(days):>9}"
                else:
                    days_str = f"{'?':>9}"
                print(
                    f"  {c['name']:<45} {c['subject'][:39]:<40} "
                    f"{c['expiration_string']:<28} {days_str}"
                )
        else:
            print("  (no SSL certificates found)")


def _write_csv(results, output_path):
    """Write virtual server data to a CSV file."""
    fieldnames = [
        "host",
        "timestamp",
        "vs_name",
        "destination",
        "ip",
        "port",
        "pool",
        "ip_protocol",
        "enabled",
        "error",
    ]
    with open(output_path, "w", newline="") as fh:
        writer = csv.DictWriter(fh, fieldnames=fieldnames)
        writer.writeheader()
        for r in results:
            if r["error"]:
                writer.writerow(
                    {
                        "host": r["host"],
                        "timestamp": r["timestamp"],
                        "error": r["error"],
                    }
                )
            elif not r["virtual_servers"]:
                writer.writerow({"host": r["host"], "timestamp": r["timestamp"]})
            else:
                for vs in r["virtual_servers"]:
                    writer.writerow(
                        {
                            "host": r["host"],
                            "timestamp": r["timestamp"],
                            "vs_name": vs["name"],
                            "destination": vs["destination"],
                            "ip": vs["ip"],
                            "port": vs["port"],
                            "pool": vs["pool"],
                            "ip_protocol": vs["ip_protocol"],
                            "enabled": vs["enabled"],
                            "error": "",
                        }
                    )
    print(f"\nResults written to: {output_path}")


def _write_certs_csv(results, output_path):
    """Write SSL certificate data to a CSV file."""
    fieldnames = [
        "host",
        "timestamp",
        "cert_name",
        "common_name",
        "subject",
        "issuer",
        "issuer_cert",
        "organization",
        "ou",
        "country",
        "state",
        "city",
        "email",
        "subject_alternative_name",
        "key_type",
        "key_size",
        "serial_number",
        "sha1_fingerprint",
        "fingerprint",
        "validity_start_string",
        "validity_start_date",
        "expiration_string",
        "expiration_date",
        "days_until_expiry",
        "cert_validators",
        "cache_path",
        "error",
    ]
    with open(output_path, "w", newline="") as fh:
        writer = csv.DictWriter(fh, fieldnames=fieldnames)
        writer.writeheader()
        for r in results:
            if r["error"]:
                writer.writerow({
                    "host": r["host"],
                    "timestamp": r["timestamp"],
                    "error": r["error"],
                })
            elif not r.get("ssl_certs"):
                writer.writerow({"host": r["host"], "timestamp": r["timestamp"]})
            else:
                for c in r["ssl_certs"]:
                    writer.writerow({
                        "host":                     r["host"],
                        "timestamp":                r["timestamp"],
                        "cert_name":                c["name"],
                        "common_name":              c["common_name"],
                        "subject":                  c["subject"],
                        "issuer":                   c["issuer"],
                        "issuer_cert":              c["issuer_cert"],
                        "organization":             c["organization"],
                        "ou":                       c["ou"],
                        "country":                  c["country"],
                        "state":                    c["state"],
                        "city":                     c["city"],
                        "email":                    c["email"],
                        "subject_alternative_name": c["subject_alternative_name"],
                        "key_type":                 c["key_type"],
                        "key_size":                 c["key_size"],
                        "serial_number":            c["serial_number"],
                        "sha1_fingerprint":         c["sha1_fingerprint"],
                        "fingerprint":              c["fingerprint"],
                        "validity_start_string":    c["validity_start_string"],
                        "validity_start_date":      c["validity_start_date"],
                        "expiration_string":        c["expiration_string"],
                        "expiration_date":          c["expiration_date"],
                        "days_until_expiry":        c["days_until_expiry"],
                        "cert_validators":          c["cert_validators"],
                        "cache_path":               c["cache_path"],
                        "error":                    "",
                    })
    print(f"SSL cert results written to: {output_path}")


def _write_json(results, output_path):
    """Write full results (including raw TMSH output) to a JSON file."""
    with open(output_path, "w") as fh:
        json.dump(results, fh, indent=2)
    print(f"JSON results written to: {output_path}")


# ---------------------------------------------------------------------------
# CLI entry point
# ---------------------------------------------------------------------------

def _parse_args():
    parser = argparse.ArgumentParser(
        description="Extract F5 LTM virtual servers via a jump server using Netmiko."
    )
    parser.add_argument(
        "--inventory", "-i",
        default="inventory.txt",
        help="Path to inventory file (default: inventory.txt)",
    )
    parser.add_argument(
        "--output-dir", "-o",
        default="raw",
        help="Base output directory (default: raw). Per-host subfolders are created automatically.",
    )
    parser.add_argument(
        "--json-output", "-j",
        default="",
        help="Also write full combined JSON output to this path",
    )
    parser.add_argument(
        "--threads", "-t",
        type=int,
        default=DEFAULT_THREADS,
        help=f"Maximum concurrent threads (default: {DEFAULT_THREADS})",
    )
    parser.add_argument(
        "--jump-host",
        default=JUMP_HOST,
        help=f"Jump server hostname (default: {JUMP_HOST})",
    )
    parser.add_argument(
        "--jump-port",
        type=int,
        default=JUMP_PORT,
        help=f"Jump server SSH port (default: {JUMP_PORT})",
    )
    parser.add_argument(
        "--jump-user",
        default=JUMP_USER,
        help="Jump server username (or set JUMP_USER env var)",
    )
    parser.add_argument(
        "--jump-key",
        default=JUMP_KEY_FILE,
        help="Path to SSH private key for jump server (or set JUMP_KEY_FILE env var)",
    )
    return parser.parse_args()


def main():
    args = _parse_args()

    # ---- Inventory --------------------------------------------------------
    if not os.path.isfile(args.inventory):
        print(f"[ERROR] Inventory file not found: {args.inventory}")
        sys.exit(1)

    hosts = load_inventory(args.inventory)
    if not hosts:
        print("[ERROR] No hosts found in inventory.")
        sys.exit(1)

    print(f"Loaded {len(hosts)} host(s) from {args.inventory}")

    # ---- Credentials (shared by jump server and all F5 devices) -------------
    username = input("Username: ").strip()
    password = getpass.getpass("Password: ")

    jump_config = {
        "host": args.jump_host,
        "port": args.jump_port,
        "user": username,
        "password": password,
        "key_file": args.jump_key,
    }

    # ---- Output paths -----------------------------------------------------
    ts_str   = datetime.now().strftime("%Y%m%d_%H%M%S")
    base_dir = args.output_dir

    # ---- Multithreaded collection -----------------------------------------
    results = []
    total = len(hosts)
    completed = 0

    print(
        f"\nConnecting to {total} device(s) via {args.jump_host} "
        f"using up to {args.threads} thread(s)...\n"
    )

    with ThreadPoolExecutor(max_workers=args.threads) as executor:
        future_to_host = {
            executor.submit(collect_virtual_servers, host, username, password, jump_config): host
            for host in hosts
        }

        for future in as_completed(future_to_host):
            host = future_to_host[future]
            try:
                result = future.result()
            except Exception as exc:
                result = {
                    "host": host,
                    "virtual_servers": [],
                    "raw_output": "",
                    "error": f"Unhandled exception: {exc}",
                    "timestamp": datetime.now().isoformat(timespec="seconds"),
                }

            results.append(result)
            completed += 1

            # Progress indicator
            status = "ERROR" if result["error"] else f"{len(result['virtual_servers'])} VS"
            print(f"  [{completed}/{total}] {host} → {status}")

    # ---- Output -----------------------------------------------------------
    _print_results(results)

    # Write per-host files into raw/<hostname>/
    print()
    for r in results:
        host_dir = os.path.join(base_dir, r["host"])
        os.makedirs(host_dir, exist_ok=True)
        _write_csv([r],       os.path.join(host_dir, f"virtual_servers_{ts_str}.csv"))
        _write_certs_csv([r], os.path.join(host_dir, f"ssl_certs_{ts_str}.csv"))

    if args.json_output:
        _write_json(results, args.json_output)

    # ---- Summary ----------------------------------------------------------
    errors = [r for r in results if r["error"]]
    ok = [r for r in results if not r["error"]]
    total_vs    = sum(len(r["virtual_servers"]) for r in ok)
    total_certs = sum(len(r.get("ssl_certs", [])) for r in ok)
    expiring    = sum(
        1 for r in ok for c in r.get("ssl_certs", [])
        if isinstance(c["days_until_expiry"], int) and c["days_until_expiry"] <= 30
    )

    print(f"\n{'='*60}")
    print(f"Summary: {len(ok)}/{total} devices OK  |  {len(errors)} errors")
    print(f"         {total_vs} virtual servers  |  {total_certs} SSL certs  |  {expiring} expiring within 30 days")
    print(f"{'='*60}")

    if errors:
        print("\nFailed devices:")
        for r in errors:
            print(f"  {r['host']}: {r['error']}")

    sys.exit(1 if errors else 0)


if __name__ == "__main__":
    main()
